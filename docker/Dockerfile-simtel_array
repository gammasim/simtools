# syntax=docker/dockerfile:1.4
# Dockerfile for sim_telarray
#
# Image with sim_telarray and tools.
#

ARG EXTRA_DEFINES="-DCTA_PROD6 -DMAXIMUM_TELESCOPES=99"
ARG SIMTEL_VERSION
ARG SIMTEL_REVISION
ARG SIMTEL_SOURCE_URL
ARG HESSIO_VERSION
ARG HESSIO_REVISION
ARG HESSIO_SOURCE_URL
ARG STDTOOLS_VERSION
ARG STDTOOLS_REVISION
ARG STDTOOLS_SOURCE_URL
ARG GSL_VERSION
ARG GSL_SHA256
ARG BASE_IMAGE
ARG BUILD_BASE_IMAGE
ARG CONTAINER_USER="simtools"
ARG CONTAINER_UID="1000"
ARG CONTAINER_GID="1000"

# hadolint global ignore=DL3033,DL3041
# - DL3033, DL3041: ignore warnings about installing non-specific versions with microdnf or yum)

# -----------------------------------------------------------------------------
# STAGE 1: source code preparation
# -----------------------------------------------------------------------------
FROM ${BASE_IMAGE} AS source_preparation
ARG SIMTEL_VERSION
ARG SIMTEL_REVISION
ARG SIMTEL_SOURCE_URL
ARG HESSIO_VERSION
ARG HESSIO_REVISION
ARG HESSIO_SOURCE_URL
ARG STDTOOLS_VERSION
ARG STDTOOLS_REVISION
ARG STDTOOLS_SOURCE_URL
ARG GSL_SHA256

RUN microdnf update -y && microdnf install -y git gzip tar && \
    microdnf clean all

WORKDIR /src

# Clone sim_telarray from CTAO gitlab
RUN --mount=type=secret,id=sim_telarray_token \
    git config --global advice.detachedHead false && \
    git clone --depth 1 --branch "${SIMTEL_VERSION}" \
      "https://oauth2:$(cat /run/secrets/sim_telarray_token)@${SIMTEL_SOURCE_URL#https://}" && \
    if [ -n "${SIMTEL_REVISION}" ]; then \
        test "$(git -C sim_telarray rev-parse HEAD)" = "${SIMTEL_REVISION}"; \
    fi

# Clone hessio from CTAO gitlab
RUN --mount=type=secret,id=hessio_token \
    git config --global advice.detachedHead false && \
    git clone --depth 1 --branch "${HESSIO_VERSION}" \
      "https://oauth2:$(cat /run/secrets/hessio_token)@${HESSIO_SOURCE_URL#https://}" && \
    if [ -n "${HESSIO_REVISION}" ]; then \
        test "$(git -C hessio rev-parse HEAD)" = "${HESSIO_REVISION}"; \
    fi

# Clone stdtools from CTAO gitlab
RUN --mount=type=secret,id=stdtools_token \
    git config --global advice.detachedHead false && \
    git clone --depth 1 --branch "${STDTOOLS_VERSION}" \
      "https://oauth2:$(cat /run/secrets/stdtools_token)@${STDTOOLS_SOURCE_URL#https://}" && \
    if [ -n "${STDTOOLS_REVISION}" ]; then \
        test "$(git -C stdtools rev-parse HEAD)" = "${STDTOOLS_REVISION}"; \
    fi

# GSL archive (tar file needs to be present in the build context)
COPY gsl.tar.gz /tmp/gsl.tar.gz
# hadolint ignore=DL4006
RUN sha256sum /tmp/gsl.tar.gz | cut -d ' ' -f1 > /src/gsl_sha256 && \
    if [ -n "${GSL_SHA256}" ]; then \
        test "$(cat /src/gsl_sha256)" = "${GSL_SHA256}"; \
    fi && \
    tar -xzf /tmp/gsl.tar.gz -C /src

# -----------------------------------------------------------------------------
# STAGE 2: build_image
# -----------------------------------------------------------------------------
FROM ${BUILD_BASE_IMAGE} AS build_image
ARG EXTRA_DEFINES
ARG SIMTEL_VERSION
ARG SIMTEL_REVISION
ARG SIMTEL_SOURCE_URL
ARG HESSIO_VERSION
ARG HESSIO_REVISION
ARG HESSIO_SOURCE_URL
ARG STDTOOLS_VERSION
ARG STDTOOLS_REVISION
ARG STDTOOLS_SOURCE_URL
ARG GSL_COMPILE="-DWITH_GSL -DWITH_GSL_RNG"
ARG GSL_VERSION
ARG GSL_SHA256

ENV GCC_PATH="/usr/bin/"
ENV HSEVENTIO="/workdir/simulation_software/hessioxxx/"
ENV STDTOOLS_PATH="/workdir/simulation_software/stdtools/"

RUN yum update -y && yum install -y \
    gcc gcc-c++ \
    automake csh diffutils patch perl \
    git make m4 which && \
    yum clean all

WORKDIR /tmp
COPY --from=source_preparation /src/gsl-${GSL_VERSION} .
RUN ./configure --prefix=/usr/local && \
    make && \
    make install && \
    ldconfig

WORKDIR /workdir/simulation_software
COPY --from=source_preparation /src .

WORKDIR /workdir/simulation_software/hessio
# Prepare hessioxxx from hessio (fudge to avoid installing dependencies like doxygen)
RUN sed -i "s|hessioxxx-prepare: build-doc doc/eventio_en.pdf doc/hessio_refman.pdf|hessioxxx-prepare:|" Makefile && \
    touch Makefile.LaTeX && touch Makefile.Common && touch ChangeLog && \
    mkdir -p doc && touch doc/eventio_en.pdf && touch doc/hessio_refman.pdf && \
    make hessioxxx-prepare && mv hessioxxx /workdir/simulation_software/

WORKDIR /workdir/simulation_software/hessioxxx
RUN make clean && make include/eventio_version.h && \
    make WITH_RPATH=1 DEFINES="${EXTRA_DEFINES} ${GSL_COMPILE}" && \
    rm -rf ./out ./doc ./root ./hessio_refman.pdf

WORKDIR /workdir/simulation_software/stdtools
RUN make WITH_RPATH=1 EXTRA_DEFINES="${EXTRA_DEFINES} ${GSL_COMPILE}" && \
    mv -v -f out/libstdtools.so ./lib && rm -rf out

WORKDIR /workdir/simulation_software/sim_telarray
# Create version.h file
RUN echo "#define VERSION \"$(date -u '+%Y.%j %H:%M:%S') UTC ($(whoami)@$(hostname))\"" > version.h && \
    echo '#define RELEASE "2025.246.0 from 2025-09-03"' >> version.h && \
    echo '#ifdef BASE_RELEASE' >> version.h && \
    echo '# undef BASE_RELEASE' >> version.h && \
    echo '#endif' >> version.h && \
    echo '#define BASE_RELEASE "2025.246.0 from 2025-09-03"' >> version.h

# build sim_telarray with debug trace (move binary to temporary location (to avoid being purged in next step)
RUN make WITH_RPATH=1 EXTRA_DEFINES="${EXTRA_DEFINES} -DDEBUG_TRACE_99 ${GSL_COMPILE}" install && \
    mv -v ./bin/sim_telarray ./sim_telarray_debug_trace

# build std sim_telarray
RUN make clean && \
    make WITH_RPATH=1 EXTRA_DEFINES="${EXTRA_DEFINES} ${GSL_COMPILE}" install && \
    mv ./sim_telarray_debug_trace ./bin/sim_telarray_debug_trace && \
    rm -fr ./cfg/* ./hegra ./hess ./doc_src ./doc ./LightEmission/out && \
    rm -vf LightEmission/LightSourcesPresentation.pdf && \
    find . -name "*.o" -exec rm -f {} \;

# Generate build_opts.yml with build information before removing Git metadata.
RUN { \
    echo "simtel_version: \"${SIMTEL_VERSION}\""; \
    echo "simtel_revision: \"$(git rev-parse HEAD)\""; \
    echo "simtel_source_url: \"${SIMTEL_SOURCE_URL}\""; \
    echo "hessio_version: \"${HESSIO_VERSION}\""; \
    echo "hessio_revision: \"$(git -C /workdir/simulation_software/hessio rev-parse HEAD)\""; \
    echo "hessio_source_url: \"${HESSIO_SOURCE_URL}\""; \
    echo "stdtools_version: \"${STDTOOLS_VERSION}\""; \
    echo "stdtools_revision: \"$(git -C /workdir/simulation_software/stdtools rev-parse HEAD)\""; \
    echo "stdtools_source_url: \"${STDTOOLS_SOURCE_URL}\""; \
    echo "gsl_version: \"${GSL_VERSION}\""; \
    echo "gsl_sha256: \"$(cat /workdir/simulation_software/gsl_sha256)\""; \
    echo "extra_defines: \"${EXTRA_DEFINES}\""; \
    echo "build_date: \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\""; \
    echo "components:"; \
    echo "  - name: \"hessioxxx\""; \
    echo "    version: \"${HESSIO_VERSION}\""; \
    echo "    build_flags: \"DEFINES=${EXTRA_DEFINES} ${GSL_COMPILE}\""; \
    echo "  - name: \"stdtools\""; \
    echo "    version: \"${STDTOOLS_VERSION}\""; \
    echo "    build_flags: \"EXTRA_DEFINES=${EXTRA_DEFINES} ${GSL_COMPILE}\""; \
    echo "  - name: \"sim_telarray\""; \
    echo "    version: \"${SIMTEL_VERSION}\""; \
    echo "    build_flags: \"EXTRA_DEFINES=${EXTRA_DEFINES} ${GSL_COMPILE}\""; \
    echo "    executables:"; \
    echo "      - \"sim_telarray\""; \
    echo "  - name: \"sim_telarray_debug_trace\""; \
    echo "    version: \"${SIMTEL_VERSION}\""; \
    echo "    build_flags: \"EXTRA_DEFINES=${EXTRA_DEFINES} -DDEBUG_TRACE_99 ${GSL_COMPILE}\""; \
    echo "    executables:"; \
    echo "      - \"sim_telarray_debug_trace\""; \
    } > build_opts.yml && \
    rm -rf /workdir/simulation_software/hessio \
           /workdir/simulation_software/hessioxxx/.git \
           /workdir/simulation_software/stdtools/.git \
           /workdir/simulation_software/sim_telarray/.git

# -----------------------------------------------------------------------------
# STAGE 3: Runtime Image
# -----------------------------------------------------------------------------
FROM ${BASE_IMAGE}
ARG CONTAINER_USER
ARG CONTAINER_UID
ARG CONTAINER_GID
WORKDIR /workdir/simulation_software
COPY --from=build_image /workdir/simulation_software/hessioxxx /workdir/simulation_software/hessioxxx
COPY --from=build_image /workdir/simulation_software/stdtools /workdir/simulation_software/stdtools
COPY --from=build_image /workdir/simulation_software/sim_telarray /workdir/simulation_software/sim_telarray
COPY --from=build_image /usr/local/lib/libgsl.so* /usr/local/lib/
COPY --from=build_image /usr/local/lib/libgslcblas.so* /usr/local/lib/

RUN microdnf update -y && microdnf install -y \
    bc findutils procps zstd && \
    microdnf clean all && \
    groupadd --gid "${CONTAINER_GID}" "${CONTAINER_USER}" && \
    useradd --uid "${CONTAINER_UID}" --gid "${CONTAINER_USER}" \
        --create-home --home-dir "/home/${CONTAINER_USER}" --shell /bin/bash "${CONTAINER_USER}" && \
    echo /usr/local/lib > /etc/ld.so.conf.d/local.conf && \
    ldconfig && \
    chown -R "${CONTAINER_UID}:${CONTAINER_GID}" /workdir "/home/${CONTAINER_USER}"

ENV LD_LIBRARY_PATH="/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

WORKDIR /workdir/simulation_software/sim_telarray
ENV HOME="/home/${CONTAINER_USER}"
USER ${CONTAINER_USER}
